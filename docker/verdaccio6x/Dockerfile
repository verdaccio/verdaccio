# Verdaccio 6.x built against the locally-built @verdaccio/* packages in this repo.
#
# The build context (dist/package.json + dist/tarballs) is generated by prepare.mjs:
#   node docker/verdaccio6x/prepare.mjs
# dist/package.json pins verdaccio@^6 and uses pnpm "overrides" to force every
# @verdaccio/* dependency to the freshly packed local tarball.
FROM node:24-alpine

ENV NODE_ENV=production
RUN corepack enable
WORKDIR /opt/verdaccio

# Install verdaccio@6 with the whole @verdaccio/* tree forced to the local builds.
# pnpm-workspace.yaml carries the overrides + nodeLinker (the repo's pnpm config style).
COPY dist/package.json ./package.json
COPY dist/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY dist/tarballs ./tarballs
RUN corepack prepare pnpm@11.1.3 --activate \
  && pnpm install --prod --no-frozen-lockfile

# Runtime layout mirrors the official verdaccio image.
RUN mkdir -p /verdaccio/storage /verdaccio/conf
COPY config.yaml /verdaccio/conf/config.yaml

# Debugging on by default (this is a local test image):
#  - DEBUG prints verdaccio's debug() output, incl. the package-filter search path.
#    Fallback default for `docker run`; docker-compose overrides it from $DEBUG.
#  - --inspect exposes the Node inspector on 9229 to attach a debugger (no break on start).
ENV DEBUG=verdaccio:*

EXPOSE 4873 9229
VOLUME /verdaccio/storage

CMD ["node", "--inspect=0.0.0.0:9229", "node_modules/verdaccio/bin/verdaccio", "--config", "/verdaccio/conf/config.yaml"]
