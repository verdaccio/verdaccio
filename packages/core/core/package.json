{
  "name": "@verdaccio/core",
  "version": "9.0.0-next-9.11",
  "description": "Verdaccio Core Components",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "author": "Juan Picado <juanpicado19@gmail.com>",
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/core/core"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "http-errors": "2.0.1",
    "http-status-codes": "2.3.0",
    "minimatch": "7.4.9",
    "process-warning": "5.0.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.5",
    "express": "5.2.1",
    "typedoc": "0.28.14",
    "vitest": "4.1.0"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "build:docs": "typedoc --options ./typedoc.json --tsconfig tsconfig.build.json",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
