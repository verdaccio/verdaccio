{
  "name": "@verdaccio/test-helper",
  "version": "5.0.0-next-9.6",
  "description": "Verdaccio Test Helpers",
  "author": "Juan Picado <juanpicado19@gmail.com>",
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "dependencies": {
    "@verdaccio/auth": "workspace:9.0.0-next-9.6",
    "@verdaccio/config": "workspace:9.0.0-next-9.6",
    "@verdaccio/core": "workspace:9.0.0-next-9.6",
    "@verdaccio/logger": "workspace:9.0.0-next-9.6",
    "@verdaccio/middleware": "workspace:9.0.0-next-9.6",
    "debug": "4.4.3",
    "express": "5.2.1",
    "supertest": "7.2.2"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.3",
    "vitest": "4.1.0"
  },
  "scripts": {
    "test": "vitest run",
    "clean": "rimraf ./build",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
