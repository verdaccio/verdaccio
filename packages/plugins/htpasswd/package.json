{
  "name": "verdaccio-htpasswd",
  "version": "14.0.0-next-9.10",
  "description": "Htpasswd Authentication Plugin for Verdaccio",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "author": "Ayush Sharma <ayush.aceit@gmail.com>",
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/plugins/htpasswd"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@verdaccio/core": "workspace:9.0.0-next-9.10",
    "@verdaccio/file-locking": "workspace:14.0.0-next-9.2",
    "apache-md5": "1.1.8",
    "bcryptjs": "2.4.3",
    "http-errors": "2.0.1",
    "debug": "4.4.3",
    "unix-crypt-td-js": "1.1.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@verdaccio/types": "workspace:14.0.0-next-9.5",
    "@verdaccio/config": "workspace:9.0.0-next-9.10",
    "@verdaccio/plugin-verifier": "workspace:1.0.0-next-9.6",
    "mockdate": "3.0.5",
    "vitest": "4.1.0"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
