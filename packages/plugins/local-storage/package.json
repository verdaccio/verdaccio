{
  "name": "@verdaccio/local-storage",
  "version": "14.0.0-next-9.10",
  "description": "Verdaccio Local Storage Plugin",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "author": "Juan Picado <juanpicado19@gmail.com>",
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/plugins/local-storage"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build/"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@verdaccio/core": "workspace:9.0.0-next-9.10",
    "@verdaccio/file-locking": "workspace:14.0.0-next-9.2",
    "debug": "4.4.3",
    "globby": "11.1.0",
    "lodash-es": "4.17.23",
    "lowdb": "7.0.1",
    "sanitize-filename": "1.6.3"
  },
  "devDependencies": {
    "@verdaccio/logger": "workspace:9.0.0-next-9.10",
    "@verdaccio/types": "workspace:14.0.0-next-9.5",
    "@types/lodash-es": "4.17.12",
    "vitest": "4.1.0"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
