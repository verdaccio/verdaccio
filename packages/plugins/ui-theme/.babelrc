{
  "extends": "../../../.babelrc",
  "presets": ["@babel/preset-env", "@babel/preset-react", "@babel/typescript"],
  "plugins": ["@babel/transform-runtime", "@emotion"],
  "env": {
    "test": {
      "presets": ["@babel/preset-env", "@babel/preset-react", "@babel/typescript"],
      "plugins": ["@babel/transform-runtime", "dynamic-import-node"]
    }
  },
  "ignore": ["**/*.d.ts"]
}
