{
  "name": "@verdaccio/package-filter",
  "version": "13.0.3",
  "description": "Package filter plugin for Verdaccio that allows blocking packages by name, scope, version or date",
  "keywords": [
    "enterprise",
    "filter",
    "modules",
    "package",
    "plugin",
    "private",
    "proxy",
    "registry",
    "repository",
    "server",
    "verdaccio"
  ],
  "homepage": "https://verdaccio.org",
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "license": "MIT",
  "author": "Vitalii Sugrobov <vsugrob@hotmail.com>",
  "contributors": [
    "Ansile <ansilet@yandex.ru> (original project)"
  ],
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/plugins/package-filter"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "clean": "rimraf ./build",
    "build": "vite build --config vite.build.config.mjs",
    "watch": "vite build --watch --config vite.build.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@verdaccio/core": "workspace:8.1.2",
    "debug": "4.4.3",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@types/debug": "4.1.12",
    "@verdaccio/config": "workspace:8.1.2",
    "@verdaccio/logger": "workspace:8.0.3",
    "@verdaccio/types": "workspace:13.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
