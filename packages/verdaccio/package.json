{
  "name": "verdaccio",
  "version": "9.0.0-next-9.6",
  "description": "A lightweight private npm proxy registry",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "verdaccio": "./bin/verdaccio"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "files": [
    "bin",
    "build"
  ],
  "scripts": {
    "clean": "rimraf ./build",
    "lint": "eslint . --ext .js,.ts",
    "test": "vitest run --testTimeout 50000 --hookTimeout 20000",
    "ge:docs": "typedoc src/index.ts --tsconfig tsconfig.build.json --plugin typedoc-plugin-markdown",
    "build": "vite build",
    "code:docker-build": "vite build",
    "build:docker": "docker build -t verdaccio/verdaccio:local . --no-cache"
  },
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/verdaccio"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "homepage": "https://verdaccio.org",
  "dependencies": {
    "@verdaccio/cli": "workspace:9.0.0-next-9.6",
    "@verdaccio/hooks": "workspace:9.0.0-next-9.6",
    "@verdaccio/logger": "workspace:9.0.0-next-9.6",
    "@verdaccio/node-api": "workspace:9.0.0-next-9.6",
    "@verdaccio/ui-theme": "workspace:9.0.0-next-9.6",
    "verdaccio-audit": "workspace:14.0.0-next-9.6",
    "verdaccio-htpasswd": "workspace:14.0.0-next-9.6",
    "@verdaccio/package-filter": "workspace:14.0.0-next-9.30",
    "debug": "4.4.3"
  },
  "devDependencies": {
    "@verdaccio/auth": "workspace:9.0.0-next-9.6",
    "@verdaccio/config": "workspace:9.0.0-next-9.6",
    "@verdaccio/core": "workspace:9.0.0-next-9.6",
    "@verdaccio/store": "workspace:9.0.0-next-9.6",
    "@verdaccio/test-helper": "workspace:5.0.0-next-9.6",
    "@verdaccio/types": "workspace:14.0.0-next-9.3",
    "get-port": "5.1.1",
    "got": "11.8.6",
    "lodash": "4.17.23",
    "nock": "13.5.6",
    "supertest": "7.1.4",
    "vitest": "4.1.0"
  },
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "preferGlobal": true,
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio",
    "logo": "https://opencollective.com/verdaccio/logo.txt"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
