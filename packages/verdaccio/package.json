{
  "name": "verdaccio",
  "version": "9.0.0-next-9.14",
  "description": "A lightweight private npm proxy registry",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "verdaccio": "./bin/verdaccio"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "files": [
    "bin",
    "build"
  ],
  "scripts": {
    "clean": "rimraf ./build",
    "lint": "eslint . --ext .js,.ts",
    "ge:docs": "typedoc src/index.ts --tsconfig tsconfig.build.json --plugin typedoc-plugin-markdown",
    "build": "vite build",
    "code:docker-build": "vite build",
    "build:docker": "docker build -t verdaccio/verdaccio:local . --no-cache"
  },
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/verdaccio"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "homepage": "https://verdaccio.org",
  "dependencies": {
    "@verdaccio/cli": "workspace:9.0.0-next-9.14",
    "@verdaccio/hooks": "workspace:9.0.0-next-9.14",
    "@verdaccio/logger": "workspace:9.0.0-next-9.14",
    "@verdaccio/node-api": "workspace:9.0.0-next-9.14",
    "@verdaccio/server": "workspace:9.0.0-next-9.14",
    "@verdaccio/ui-theme": "workspace:9.0.0-next-9.14",
    "verdaccio-audit": "workspace:14.0.0-next-9.14",
    "verdaccio-htpasswd": "workspace:14.0.0-next-9.14",
    "@verdaccio/package-filter": "workspace:14.0.0-next-9.38",
    "debug": "4.4.3"
  },
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "preferGlobal": true,
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio",
    "logo": "https://opencollective.com/verdaccio/logo.txt"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
