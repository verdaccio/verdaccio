{
  "name": "@verdaccio/server",
  "version": "9.0.0-next-9.8",
  "description": "Verdaccio Express Server",
  "main": "./build/index.js",
  "types": "build/index.d.ts",
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/server/express"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@verdaccio/api": "workspace:9.0.0-next-9.8",
    "@verdaccio/auth": "workspace:9.0.0-next-9.8",
    "@verdaccio/core": "workspace:9.0.0-next-9.8",
    "@verdaccio/config": "workspace:9.0.0-next-9.8",
    "@verdaccio/loaders": "workspace:9.0.0-next-9.8",
    "@verdaccio/logger": "workspace:9.0.0-next-9.8",
    "@verdaccio/middleware": "workspace:9.0.0-next-9.8",
    "@verdaccio/store": "workspace:9.0.0-next-9.8",
    "@verdaccio/web": "workspace:9.0.0-next-9.8",
    "verdaccio-audit": "workspace:14.0.0-next-9.8",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "debug": "4.4.3",
    "express": "5.2.1",
    "lodash-es": "4.17.23"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.4",
    "@types/lodash-es": "4.17.12",
    "supertest": "7.1.4",
    "vitest": "4.1.0"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
