{
  "name": "@verdaccio/store",
  "version": "9.0.0-next-9.6",
  "description": "Verdaccio Storage",
  "main": "./build/index.js",
  "types": "build/index.d.ts",
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/store"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run --testTimeout 20000",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "dependencies": {
    "@verdaccio/config": "workspace:9.0.0-next-9.6",
    "@verdaccio/core": "workspace:9.0.0-next-9.6",
    "@verdaccio/loaders": "workspace:9.0.0-next-9.6",
    "@verdaccio/local-storage": "workspace:14.0.0-next-9.6",
    "@verdaccio/logger": "workspace:9.0.0-next-9.6",
    "@verdaccio/proxy": "workspace:9.0.0-next-9.6",
    "@verdaccio/search": "workspace:9.0.0-next-9.6",
    "@verdaccio/tarball": "workspace:14.0.0-next-9.6",
    "@verdaccio/url": "workspace:14.0.0-next-9.6",
    "debug": "4.4.3",
    "lodash": "4.17.23",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@verdaccio/test-helper": "workspace:5.0.0-next-9.6",
    "@verdaccio/types": "workspace:14.0.0-next-9.3",
    "mockdate": "3.0.5",
    "nock": "13.5.6",
    "node-mocks-http": "1.17.2",
    "vitest": "4.1.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
