{
  "name": "@verdaccio/cli",
  "version": "9.0.0-next-9.9",
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "bin": {
    "verdaccio": "./bin/verdaccio",
    "verdaccio-cli": "./bin/verdaccio"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "homepage": "https://verdaccio.org",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "description": "Verdaccio CLI",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build",
    "start": "ts-node src/index.ts"
  },
  "dependencies": {
    "@verdaccio/config": "workspace:9.0.0-next-9.9",
    "@verdaccio/core": "workspace:9.0.0-next-9.9",
    "@verdaccio/logger": "workspace:9.0.0-next-9.9",
    "@verdaccio/node-api": "workspace:9.0.0-next-9.9",
    "@verdaccio/server": "workspace:9.0.0-next-9.9",
    "clipanion": "4.0.0-rc.4",
    "envinfo": "7.19.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.4",
    "ts-node": "10.9.2",
    "vitest": "4.1.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
