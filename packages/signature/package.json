{
  "name": "@verdaccio/signature",
  "version": "9.0.0-next-9.11",
  "description": "Verdaccio Signature Utilities",
  "main": "./build/index.js",
  "types": "build/index.d.ts",
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/signature"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "dependencies": {
    "@verdaccio/config": "workspace:9.0.0-next-9.11",
    "@verdaccio/core": "workspace:9.0.0-next-9.11",
    "jsonwebtoken": "9.0.3",
    "debug": "4.4.3"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.5",
    "vitest": "4.1.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
