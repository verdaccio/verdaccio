{
  "name": "@verdaccio/search",
  "version": "9.0.0-next-9.12",
  "description": "Verdaccio Search Proxy",
  "main": "./build/index.js",
  "types": "build/index.d.ts",
  "author": {
    "name": "Juan Picado",
    "email": "juanpicado19@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio",
    "directory": "packages/search"
  },
  "bugs": {
    "url": "https://github.com/verdaccio/verdaccio/issues"
  },
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "test": "vitest run",
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "dependencies": {
    "@verdaccio/config": "workspace:9.0.0-next-9.12",
    "@verdaccio/core": "workspace:9.0.0-next-9.12",
    "@verdaccio/logger": "workspace:9.0.0-next-9.12",
    "@verdaccio/proxy": "workspace:9.0.0-next-9.12",
    "debug": "4.4.3",
    "lodash-es": "4.17.23"
  },
  "devDependencies": {
    "@verdaccio/types": "workspace:14.0.0-next-9.5",
    "@types/lodash-es": "4.17.12",
    "nock": "13.5.6",
    "vitest": "4.1.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "module": "./build/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  }
}
