{
  "name": "@verdaccio/ui-components",
  "version": "5.0.0-next-9.5",
  "description": "Verdaccio UI Components",
  "author": "Juan Picado <juanpicado19@gmail.com>",
  "license": "MIT",
  "homepage": "https://verdaccio.org",
  "main": "./build/index.js",
  "module": "./build/index.mjs",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    },
    "./build/*": "./build/*"
  },
  "scripts": {
    "test": "cross-env TZ=UTC vitest run",
    "clean": "rimraf ./build",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "build:js": "vite build",
    "watch": "vite build --watch",
    "build": "pnpm run build:js && pnpm run build:types",
    "start": "cross-env BROWSER=none storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.11.5",
    "@hookform/resolvers": "5.2.2",
    "@microlink/react-json-view": "1.31.12",
    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.7",
    "@verdaccio/ui-i18n": "workspace:10.0.0-next-9.2",
    "country-flag-icons": "1.5.21",
    "dayjs": "1.11.18",
    "dompurify": "3.3.1",
    "highlight.js": "11.11.1",
    "i18next": "25.8.0",
    "js-base64": "3.7.8",
    "localstorage-memory": "1.0.3",
    "lodash": "4.17.23",
    "marked": "17.0.1",
    "marked-highlight": "2.2.3",
    "normalize.css": "8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.71.1",
    "react-i18next": "16.5.4",
    "react-markdown": "10.1.0",
    "react-router": "7.13.0",
    "react-virtualized": "9.22.6",
    "semver": "7.7.4",
    "swr": "2.3.8",
    "validator": "13.15.26",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.2.17",
    "@storybook/addon-links": "10.2.17",
    "@storybook/react-vite": "10.2.17",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.10.13",
    "@verdaccio/types": "workspace:14.0.0-next-9.3",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "^8.0.0",
    "eslint-plugin-storybook": "10.2.17",
    "eslint-plugin-verdaccio": "10.0.0",
    "jsdom": "28.1.0",
    "mockdate": "3.0.5",
    "msw": "2.12.10",
    "msw-storybook-addon": "2.0.6",
    "mutationobserver-shim": "0.3.7",
    "storybook": "10.2.17",
    "vitest": "4.1.0",
    "whatwg-fetch": "3.6.20"
  },
  "resolutions": {
    "msw": "2.12.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
