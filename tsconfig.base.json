{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "noImplicitAny": false,
    "strict": true,
    "declaration": true,
    "strictNullChecks": true,
    "types": ["node", "express"],
    "resolveJsonModule": true,
    // "preserveSymlinks": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "types/*.d.ts"],
  "exclude": [
    "**/build",
    "node_modules",
    "**/node_modules",
    "**/coverage",
    "**/*.spec.ts",
    "**/test",
    "**/__tests__",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "packages/api"
    },
    {
      "path": "packages/auth"
    },
    {
      "path": "packages/config"
    },
    {
      "path": "packages/hooks"
    },
    {
      "path": "packages/loaders"
    },
    {
      "path": "packages/middleware"
    },
    {
      "path": "packages/proxy"
    },
    {
      "path": "packages/search-indexer"
    },
    {
      "path": "packages/search"
    },
    {
      "path": "packages/signature"
    },
    {
      "path": "packages/store"
    },
    {
      "path": "packages/utils"
    },
    {
      "path": "packages/web"
    },
    {
      "path": "packages/core/core"
    },
    {
      "path": "packages/core/file-locking"
    },
    {
      "path": "packages/core/tarball"
    },
    {
      "path": "packages/core/types"
    },
    {
      "path": "packages/core/url"
    },
    {
      "path": "packages/server/express"
    },
    {
      "path": "packages/logger/logger-commons"
    },
    {
      "path": "packages/logger/logger-prettify"
    },
    {
      "path": "packages/logger/logger"
    },
    {
      "path": "packages/plugins/audit"
    },
    {
      "path": "packages/plugins/auth-memory"
    },
    {
      "path": "packages/plugins/htpasswd"
    },
    {
      "path": "packages/plugins/memory"
    },
    {
      "path": "packages/plugins/local-storage"
    },
    {
      "path": "packages/plugins/package-filter"
    }
  ]
}
