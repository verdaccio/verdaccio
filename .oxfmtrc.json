{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "ignorePatterns": [
    ".cache/",
    "**/corrupted-package/package.json",
    "**/corrupted.json",
    "**/invalid.js",
    "**/invalid.json",
    "**/verdaccio-corrupted.db.json",
    "**/wrong.package.json",
    "CHANGELOG.md",
    ".changeset/",
    "README.md",
    "CONTRIBUTORS.md",
    "test/unit/partials/config/js/*",
    "node_modules/",
    "**/coverage/**",
    "**/build/*.js",
    "build/*",
    ".github/",
    ".vscode/",
    "pnpm-lock.yaml",
    "test/functional/store/*",
    "storage_default_storage/*",
    ".npmignore",
    ".gitignore",
    "*.ico",
    "test/unit/partials/mock-store/**"
  ],
  "jsxSingleQuote": true,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
