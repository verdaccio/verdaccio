{
  "name": "verdaccio",
  "version": "6.7.4",
  "description": "A lightweight private npm proxy registry",
  "keywords": [
    "enterprise",
    "modules",
    "package",
    "private",
    "proxy",
    "registry",
    "repository",
    "server",
    "verdaccio"
  ],
  "homepage": "https://verdaccio.org",
  "license": "MIT",
  "author": {
    "name": "Verdaccio Maintainers",
    "email": "verdaccio.npm@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/verdaccio/verdaccio"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "bin": "./bin/verdaccio",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "changeset": "changeset",
    "changeset:check": "changeset status --since=origin/6.x",
    "ci:version": "yarn ci:version:changeset && yarn install --no-immutable",
    "ci:version:changeset": "changeset version",
    "ci:publish": "changeset publish",
    "type-check": "tsc --noEmit",
    "cache:clean": "yarn cache clean --mirror && yarn cache clean --all",
    "type-check:watch": "yarn run type-check -- --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "cross-env NODE_ENV=test TZ=UTC FORCE_COLOR=1 vitest run",
    "pre:ci": "yarn run lint",
    "lint:ts": "yarn run type-check",
    "lint": "oxlint --max-warnings 28",
    "lint:lockfile": "echo 'No lockfile linting available'",
    "start": "yarn babel-node --extensions \".ts,.tsx\" src/lib/cli --inspect",
    "start:brk": "yarn babel-node --extensions \".ts,.tsx\" src/lib/cli --inspect-brk",
    "start:debug": "yarn node debug/bootstrap.js",
    "start:run-server": "yarn node debug/bootstrap-runserver.js",
    "build": "rm -Rf build && PACKAGE_VERSION=$(node -p \"require('./package.json').version\")  yarn babel src/ --out-dir build/ --copy-files --extensions \".ts,.tsx\" --source-maps inline",
    "code:types": "tsc --emitDeclarationOnly -p tsconfig.json",
    "code:docker-build": "yarn babel src/ --out-dir build/ --copy-files --extensions \".ts,.tsx\"",
    "docker": "docker build -t verdaccio/verdaccio:local . --no-cache",
    "docker:run": "docker run -it --rm -p 4873:4873 -e \"DEBUG=verdaccio*\" verdaccio/verdaccio:local",
    "e2e:ui:start": "node bin/verdaccio --config ./scripts/e2e-ui-config.yaml",
    "e2e:ui:run": "cypress run",
    "e2e:ui:open": "cypress open",
    "e2e:ui:local": "./scripts/e2e-ui-local.sh",
    "e2e:ui:local:open": "./scripts/e2e-ui-local.sh --open",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@cypress/request": "3.0.10",
    "@verdaccio/auth": "8.0.4",
    "@verdaccio/config": "8.1.2",
    "@verdaccio/core": "8.1.2",
    "@verdaccio/hooks": "8.0.3",
    "@verdaccio/loaders": "8.0.3",
    "@verdaccio/local-storage-legacy": "11.3.4",
    "@verdaccio/logger": "8.0.3",
    "@verdaccio/middleware": "8.0.5",
    "@verdaccio/package-filter": "13.0.3",
    "@verdaccio/search-indexer": "8.0.2",
    "@verdaccio/signature": "8.0.3",
    "@verdaccio/streams": "10.2.5",
    "@verdaccio/tarball": "13.0.3",
    "@verdaccio/ui-theme": "9.0.0-next-9.20",
    "@verdaccio/url": "13.0.3",
    "@verdaccio/utils": "8.1.3",
    "JSONStream": "1.3.5",
    "async": "3.2.6",
    "clipanion": "4.0.0-rc.4",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "debug": "4.4.3",
    "envinfo": "7.21.0",
    "express": "4.22.2",
    "lodash": "4.18.1",
    "lru-cache": "7.18.3",
    "mime": "3.0.0",
    "semver": "7.8.2",
    "verdaccio-audit": "13.0.3",
    "verdaccio-htpasswd": "13.0.3"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@babel/register": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.31.0",
    "@changesets/get-dependents-graph": "2.1.4",
    "@types/async": "3.2.25",
    "@types/debug": "4.1.13",
    "@types/express": "4.17.25",
    "@types/express-serve-static-core": "4.19.8",
    "@types/http-errors": "2.0.5",
    "@types/lodash": "4.17.24",
    "@types/mime": "3.0.4",
    "@types/minimatch": "5.1.2",
    "@types/node": "20.19.41",
    "@types/request": "2.48.13",
    "@types/semver": "7.7.1",
    "@types/supertest": "6.0.3",
    "@verdaccio-scope/verdaccio-auth-foo": "0.0.2",
    "@verdaccio/e2e-cli": "2.10.2",
    "@verdaccio/e2e-ui": "2.4.1",
    "@verdaccio/test-helper": "4.0.5",
    "@verdaccio/types": "13.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "babel-plugin-transform-inline-environment-variables": "0.4.4",
    "cross-env": "10.1.0",
    "cypress": "15.16.0",
    "fs-extra": "11.3.5",
    "get-port": "7.2.0",
    "kleur": "4.1.5",
    "nock": "13.5.6",
    "node-mocks-http": "^1.17.2",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "selfsigned": "5.5.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "verdaccio-auth-memory": "13.0.3",
    "verdaccio-memory": "10.4.6",
    "vitest": "4.1.8"
  },
  "resolutions": {
    "@cypress/request/form-data": "4.0.6",
    "@types/express-serve-static-core": "4.19.8",
    "@types/serve-static": "1.15.10",
    "ajv/fast-uri": "3.1.2",
    "express/path-to-regexp": "0.1.13",
    "lowdb/lodash": "4.18.1"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.15.0",
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio",
    "logo": "https://opencollective.com/verdaccio/logo.txt"
  }
}
