{
  "name": "verdaccio-dev",
  "private": true,
  "homepage": "https://verdaccio.org",
  "license": "MIT",
  "author": {
    "name": "Verdaccio Maintainers",
    "email": "verdaccio.npm@gmail.com"
  },
  "repository": {
    "type": "https",
    "url": "https://github.com/verdaccio/verdaccio"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "scripts": {
    "prepare": "husky install",
    "clean": "pnpm --filter \"./packages/**\" run clean",
    "build": "pnpm --filter \"./packages/**\" run build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --max-warnings 28",
    "lint:fix": "oxlint --fix",
    "test": "pnpm --filter \"./packages/**\" --filter \"!./packages/e2e/**\" run test",
    "test:e2e": "pnpm --filter \"./packages/e2e/**\" run test",
    "changeset": "changeset",
    "changeset:check": "changeset status --since-master",
    "ci:version": "run-s ci:version:changeset ci:version:install",
    "ci:version:install": "pnpm install --frozen-lockfile=false",
    "ci:version:changeset": "changeset version",
    "ci:publish": "changeset publish",
    "ts:ref": "update-ts-references --discardComments --rootConfigName tsconfig.base.json",
    "postinstall": "husky install",
    "local:snapshots": "changeset version --snapshot",
    "local:publish": "cross-env npm_config_registry=http://localhost:4873 changeset publish --no-git-tag",
    "verdaccio": "node docker/verdaccio6x/prepare.mjs && docker compose -f docker/verdaccio6x/docker-compose.yml up --build",
    "verdaccio:build": "node docker/verdaccio6x/prepare.mjs && docker compose -f docker/verdaccio6x/docker-compose.yml build",
    "verdaccio:run": "docker compose -f docker/verdaccio6x/docker-compose.yml up",
    "verdaccio:down": "docker compose -f docker/verdaccio6x/docker-compose.yml down"
  },
  "devDependencies": {
    "@babel/cli": "7.28.3",
    "@babel/core": "7.29.6",
    "@babel/plugin-proposal-decorators": "7.28.0",
    "@babel/plugin-proposal-function-sent": "7.27.1",
    "@babel/plugin-proposal-throw-expressions": "7.27.1",
    "@babel/plugin-syntax-import-meta": "7.10.4",
    "@babel/plugin-transform-async-to-generator": "7.27.1",
    "@babel/plugin-transform-class-properties": "7.27.1",
    "@babel/plugin-transform-classes": "7.28.4",
    "@babel/plugin-transform-export-namespace-from": "7.27.1",
    "@babel/plugin-transform-json-strings": "7.27.1",
    "@babel/plugin-transform-nullish-coalescing-operator": "7.27.1",
    "@babel/plugin-transform-numeric-separator": "7.27.1",
    "@babel/plugin-transform-object-rest-spread": "7.28.4",
    "@babel/plugin-transform-optional-chaining": "7.27.1",
    "@babel/plugin-transform-runtime": "7.28.3",
    "@babel/preset-env": "7.28.3",
    "@babel/preset-typescript": "7.24.7",
    "@babel/register": "7.28.3",
    "@babel/runtime": "7.28.4",
    "@changesets/cli": "2.27.12",
    "@types/body-parser": "1.19.5",
    "@types/connect": "3.4.38",
    "@types/cookiejar": "2.1.5",
    "@types/debug": "4.1.12",
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "4.19.5",
    "@types/http-errors": "2.0.4",
    "@types/jsonwebtoken": "9.0.6",
    "@types/lodash": "4.17.7",
    "@types/mime": "3.0.4",
    "@types/minimatch": "5.1.2",
    "@types/ms": "2.1.0",
    "@types/node": "20.14.12",
    "@types/node-fetch": "2.6.11",
    "@types/qs": "6.9.15",
    "@types/range-parser": "1.2.7",
    "@types/semver": "7.5.8",
    "@types/send": "0.17.4",
    "@types/serve-static": "1.15.7",
    "@types/superagent": "4.1.24",
    "@types/supertest": "2.0.16",
    "@types/validator": "13.12.0",
    "@verdaccio/types": "workspace:*",
    "@vitest/coverage-v8": "4.1.2",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "debug": "4.4.3",
    "husky": "8.0.3",
    "nock": "13.5.6",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "rimraf": "5.0.10",
    "semver": "7.7.4",
    "supertest": "7.1.4",
    "typescript": "5.3.3",
    "undici-types": "5.28.4",
    "update-ts-references": "3.6.2",
    "verdaccio-audit": "workspace:*",
    "verdaccio-auth-memory": "workspace:*",
    "verdaccio-htpasswd": "workspace:*",
    "vite": "8.0.16",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
