{
  "name": "verdaccio",
  "version": "7.0.0-next-7.22",
  "description": "A lightweight private npm proxy registry",
  "author": {
    "name": "Verdaccio Maintainers",
    "email": "verdaccio.npm@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/verdaccio/verdaccio"
  },
  "homepage": "https://verdaccio.org",
  "main": "build/cjs/index.cjs",
  "module": "build/esm/index.mjs",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/esm/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/cjs/index.cjs"
      }
    }
  },
  "bin": "./bin/verdaccio",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio"
  },
  "dependencies": {
    "@verdaccio/auth": "9.0.0-next-9.20",
    "@verdaccio/cli": "9.0.0-next-9.20",
    "@verdaccio/config": "9.0.0-next-9.20",
    "@verdaccio/core": "9.0.0-next-9.20",
    "@verdaccio/loaders": "9.0.0-next-9.20",
    "@verdaccio/local-storage": "14.0.0-next-9.20",
    "@verdaccio/logger": "9.0.0-next-9.20",
    "@verdaccio/middleware": "9.0.0-next-9.20",
    "@verdaccio/node-api": "9.0.0-next-9.20",
    "@verdaccio/proxy": "9.0.0-next-9.20",
    "@verdaccio/server": "9.0.0-next-9.20",
    "@verdaccio/store": "9.0.0-next-9.20",
    "@verdaccio/ui-theme": "9.0.0-next-9.20",
    "debug": "4.4.3",
    "express": "5.2.1",
    "lodash-es": "4.18.1",
    "semver": "7.7.4",
    "verdaccio-audit": "14.0.0-next-9.20",
    "verdaccio-htpasswd": "14.0.0-next-9.20"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.27.12",
    "@changesets/get-dependents-graph": "2.1.3",
    "@cypress/request": "3.0.10",
    "@orama/orama": "1.2.11",
    "@trivago/prettier-plugin-sort-imports": "5.2.2",
    "@types/debug": "4.1.12",
    "@types/express": "5.0.6",
    "@types/http-errors": "2.0.5",
    "@types/lodash-es": "^4",
    "@types/minimatch": "5.1.2",
    "@types/node": "25.5.0",
    "@types/semver": "7.7.1",
    "@types/supertest": "6.0.3",
    "@verdaccio-scope/verdaccio-auth-foo": "0.0.2",
    "@verdaccio/api": "9.0.0-next-9.20",
    "@verdaccio/e2e-cli": "2.10.2",
    "@verdaccio/eslint-config": "13.1.2",
    "@verdaccio/test-helper": "5.0.0-next-9.21",
    "@verdaccio/types": "14.0.0-next-9.11",
    "@verdaccio/web": "9.0.0-next-9.20",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "1.6.13",
    "cross-env": "10.1.0",
    "eslint": "10.0.3",
    "eslint-plugin-cypress": "6.1.0",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-verdaccio": "10.1.0",
    "fs-extra": "11.3.2",
    "get-port": "7.1.0",
    "kleur": "4.1.5",
    "nock": "13.5.6",
    "node-mocks-http": "^1.17.2",
    "prettier": "3.6.2",
    "selfsigned": "5.5.0",
    "supertest": "7.2.2",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "verdaccio-auth-memory": "14.0.0-next-9.20",
    "verdaccio-memory": "14.0.0-next-9.20",
    "vite": "8.0.10",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2"
  },
  "keywords": [
    "private",
    "package",
    "repository",
    "registry",
    "enterprise",
    "modules",
    "proxy",
    "server",
    "verdaccio"
  ],
  "scripts": {
    "ci:version": "pnpm ci:version:changeset && pnpm ci:version:install",
    "ci:version:changeset": "changeset version",
    "ci:version:install": "pnpm install --frozen-lockfile=false --config.prefer-online=true",
    "ci:publish": "changeset publish",
    "type-check": "tsc --noEmit",
    "cache:clean": "pnpm store prune",
    "type-check:watch": "pnpm run type-check -- --watch",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,yml,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,yml,yaml,md}\"",
    "test": "cross-env NODE_ENV=test TZ=UTC FORCE_COLOR=1 vitest run",
    "pre:ci": "pnpm run lint",
    "lint:ts": "pnpm run type-check",
    "lint": "eslint \"**/*.{js,jsx,ts}\"",
    "lint:lockfile": "echo 'No lockfile linting available'",
    "start": "NODE_OPTIONS='--trace-deprecation' tsx src/lib/cli",
    "start:brk": "tsx src/lib/cli --inspect-brk",
    "start:debug": "tsx --inspect debug/run-server.ts",
    "start:run-server": "tsx debug/run-server.ts",
    "build": "rm -Rf build && vite build",
    "docker": "docker build -t verdaccio/verdaccio:local . --no-cache",
    "docker:run": "docker run -it --rm -p 4873:4873 -e \"DEBUG=verdaccio*\" verdaccio/verdaccio:local"
  },
  "engines": {
    "node": ">=24"
  },
  "preferGlobal": true,
  "license": "MIT",
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/verdaccio",
    "logo": "https://opencollective.com/verdaccio/logo.txt"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
